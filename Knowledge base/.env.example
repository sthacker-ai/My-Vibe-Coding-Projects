KNOWLEDGEBASE_CONTENT_DIR=./content
OBSIDIAN_VAULT_DIR=

# ─── X/Twitter import ────────────────────────────────────────────────────────
SCRAPE_TARGET_HANDLE=your_x_handle
X_STORAGE_STATE_PATH=./data/private/x-storage-state.json
SCRAPE_DAILY_LIMIT=10
SCRAPE_REQUEST_DELAY_MIN_MS=1400
SCRAPE_REQUEST_DELAY_MAX_MS=3200
SCRAPE_MAX_SCROLLS=40
SCRAPE_IDLE_SCROLL_LIMIT=6

# X cookie auth (from browser DevTools > Application > Cookies > https://x.com)
X_AUTH_TOKEN=your_x_auth_token_here
X_CT0=your_x_ct0_token_here

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Leave OPENROUTER_API_KEY blank to use local Ollama only.
# If set, scripts will try OpenRouter (primary → fallback), then Ollama as last resort.

OPENROUTER_API_KEY=
OPENROUTER_MODEL_PRIMARY=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL_FALLBACK=qwen/qwen3-235b-a22b:free

# Local Ollama (always used as last-resort fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b

# ─── Video / Transcription ────────────────────────────────────────────────────
# Whisper model size: tiny | base | small | medium | large-v3
# small = good default. medium = better for technical content.
WHISPER_MODEL=small
